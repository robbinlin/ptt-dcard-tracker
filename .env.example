# 複製此檔案為 .env 並依需求修改

# 預設關鍵字（JSON 陣列格式）
DEFAULT_KEYWORDS=["運動", "訓練", "體育", "教練"]

# PTT 看板（JSON 陣列格式）
PTT_BOARDS=["Gossiping", "Stock", "Tech_Job", "HatePolitics", "NBA"]

# Dcard 論壇
DCARD_FORUMS=["trending", "tech", "job", "relationship", "taiwan"]

# 熱門評分權重（加總建議為 1.0）
WEIGHT_COMMENTS=0.5
WEIGHT_REACTIONS=0.3
WEIGHT_KEYWORD_FREQ=0.2

# 時間衰減半衰期（小時）
TIME_HALF_LIFE_HOURS=24

# 排程間隔（分鐘）
CRAWL_INTERVAL_MINUTES=60

# 每來源最多爬取文章數
MAX_ARTICLES_PER_SOURCE=100

# API 伺服器設定
API_HOST=0.0.0.0
API_PORT=8000
